# =============================================================================
# Docker / school-erp-infra (recommended)
# =============================================================================
# `docker-compose.local.yml` injects NEXT_PUBLIC_* from:
#   school-erp-infra/env/.env.local
# You usually do **not** need a admin-web/.env when using make dev.
#
# Copy this file only for **local Next without Docker**, e.g.:
#   cp .env.example .env.local
# =============================================================================

# Backend API (non-Docker: Flask on 5001; Docker+nginx: often leave empty and use gateway)
NEXT_PUBLIC_API_URL_DEV=http://localhost:5001

NEXT_PUBLIC_API_URL=

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=